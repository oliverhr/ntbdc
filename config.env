# vim: set ft=bash:

# Docker Compose Variables
PROJECT_NAME="ntbdc"

# Relative path from project root to the compose files
COMPOSE_DIR="docker"

# Order of compose files to be loaded
declare -ra COMPOSE_FILES=(
    "$COMPOSE_DIR/compose.postgres.yml"
    "$COMPOSE_DIR/compose.redis.yml"
    "$COMPOSE_DIR/compose.nautobot.deploy.yml"
    "$COMPOSE_DIR/compose.nautobot.build.yml"
)

# Docker Compose Arguments
declare -A COMPOSE_ARGS=(
    [PYTHON_SUPPORTED_RANGE]=">=3.9.2,<3.13"
    [PYTHON_VERSION]="3.12"
    [NAUTOBOT_VERSION]="3.0.7"
    [NAUTOBOT_REGISTRY_URL]="ghcr.io/nautobot"
    [PUBLIC_REGISTRY_URL]="docker.io/library"
)
